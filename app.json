{
  "expo": {
    "name": "Contriba",
    "slug": "contriba",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E60012"
    },
    "developmentClient": {
      "silentLaunch": false
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.contriba.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow Contriba to access your photos to set event cover photos.",
        "NSCameraUsageDescription": "Allow Contriba to access your camera to take event cover photos.",
        "NSPhotoLibraryAddUsageDescription": "Allow Contriba to save photos to your library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "edgeToEdgeEnabled": true,
      "googleServicesFile": "./google-services.json",
      "package": "com.contriba.app",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Contriba to access your photos to set event cover photos.",
          "cameraPermission": "Allow Contriba to access your camera to take event cover photos."
        }
      ],
      "expo-web-browser",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.2587634943-vr1d200lsoe8prm76h9pouk0aus2se36"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d6b09666-6978-45fd-8cc4-a6e71af3b5a1"
      }
    }
  }
}